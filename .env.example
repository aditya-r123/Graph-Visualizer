# ----- OpenAI (server-side only) -----
# Used by /api/ai/* serverless functions. Never expose this to the client.
OPENAI_API_KEY=sk-...

# ----- Supabase -----
# Project URL and anon key are public-safe (clients use them); the service
# role key is server-only and bypasses RLS — keep it secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ----- Stripe -----
# Test keys (sk_test_*, pk_test_*) for development; live keys for production.
STRIPE_SECRET_KEY=sk_test_...
# Publishable key is safe to expose to the browser — used by Stripe.js to
# initialize the embedded checkout. Same Dashboard page as the secret key.
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...           # ID of the Pro recurring price
STRIPE_WEBHOOK_SECRET=whsec_...     # `stripe listen` prints this locally;
                                    # production: from Stripe Dashboard webhook.

# Used in checkout success/cancel URLs. Set to your prod domain in Vercel.
APP_ORIGIN=http://localhost:3005

# ----- EmailJS (existing) -----
EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
